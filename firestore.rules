rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transcripts
    // Document ID: {transcriptId}
    // Fields:
    //   - uid: string (required) - The UID of the user who owns this transcript.
    //   - title: string (required) - The title of the video/audio.
    //   - transcript: string (required) - The full text of the transcription.
    //   - date: string (required) - The date the transcription was saved.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isValidTranscript(data) {
      return hasRequiredFields(['uid', 'title', 'transcript', 'date']) &&
             hasOnlyAllowedFields(['uid', 'title', 'transcript', 'date']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.transcript is string && data.transcript.size() > 0 && data.transcript.size() < 1000000 &&
             data.date is string;
    }

    match /transcripts/{transcriptId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidTranscript(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && isValidTranscript(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
